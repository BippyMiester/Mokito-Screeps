'use strict';

// Bot: Mokito
// Version: 1.0.0
// Entry point for Screeps

console.log('*** Greetings from Mokito! ***');
console.log('Current Game Tick:', Game.time);

// Main game loop - executed every tick
module.exports.loop = function() {
    console.log('Mokito is running! Tick:', Game.time);
    
    // Clean up dead creeps from memory
    for (const name in Memory.creeps) {
        if (!Game.creeps[name]) {
            delete Memory.creeps[name];
            console.log('Clearing non-existing creep memory:', name);
        }
    }
    
    // Basic room management
    for (const roomName in Game.rooms) {
        const room = Game.rooms[roomName];
        
        if (room.controller && room.controller.my) {
            // Spawn creeps if needed
            manageRoom(room);
        }
    }
    
    // Run creeps
    for (const name in Game.creeps) {
        const creep = Game.creeps[name];
        runCreep(creep);
    }
};

function manageRoom(room) {
    const spawn = room.find(FIND_MY_SPAWNS)[0];
    if (!spawn) return;
    
    const harvesters = _.filter(Game.creeps, (creep) => creep.memory.role === 'harvester');
    
    if (harvesters.length < 2) {
        spawn.spawnCreep([WORK, CARRY, MOVE], 'Harvester' + Game.time, {
            memory: { role: 'harvester' }
        });
    }
}

function runCreep(creep) {
    if (creep.memory.role === 'harvester') {
        if (creep.store.getFreeCapacity() > 0) {
            const sources = creep.room.find(FIND_SOURCES);
            if (creep.harvest(sources[0]) === ERR_NOT_IN_RANGE) {
                creep.moveTo(sources[0]);
            }
        } else {
            if (creep.transfer(Game.spawns['Spawn1'], RESOURCE_ENERGY) === ERR_NOT_IN_RANGE) {
                creep.moveTo(Game.spawns['Spawn1']);
            }
        }
    }
}
