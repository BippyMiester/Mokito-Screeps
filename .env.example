# Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials to version control

# GitHub Credentials
GITHUB_USERNAME=your_github_username
GITHUB_PAT=ghp_your_personal_access_token_here

# Steam Web API Key (for Screeps server)
# Get your key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Notes:
# - GITHUB_PAT needs 'repo' scope for pushing to repositories
# - STEAM_API_KEY is required for Screeps server authentication
# - Never share or commit the actual .env file
# - Keep your credentials secure
